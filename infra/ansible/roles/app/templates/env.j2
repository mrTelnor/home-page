# PostgreSQL
POSTGRES_USER={{ vault_postgres_user }}
POSTGRES_PASSWORD={{ vault_postgres_password }}
POSTGRES_DB={{ vault_postgres_db }}

# Domain
DOMAIN={{ vault_domain }}
ACME_EMAIL={{ vault_acme_email }}

# IP whitelist for admin panels
HOME_IP={{ vault_home_ip }}

# Backend
DATABASE_URL=postgresql+asyncpg://{{ vault_postgres_user }}:{{ vault_postgres_password }}@postgres:5432/{{ vault_postgres_db }}
JWT_SECRET={{ vault_jwt_secret }}
INVITE_CODE={{ vault_invite_code }}
CRON_SECRET={{ vault_cron_secret }}
TELEGRAM_BOT_TOKEN={{ vault_telegram_bot_token }}
TELEGRAM_BOT_USERNAME={{ vault_telegram_bot_username }}
BOT_SECRET={{ vault_bot_secret }}
WEBHOOK_HOST=https://bot.{{ vault_domain }}

# Yandex.Disk backup
YADISK_USER={{ vault_yadisk_user }}
YADISK_APP_PASSWORD={{ vault_yadisk_app_password }}
