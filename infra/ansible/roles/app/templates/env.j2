# PostgreSQL
POSTGRES_USER={{ vault_postgres_user }}
POSTGRES_PASSWORD={{ vault_postgres_password }}
POSTGRES_DB={{ vault_postgres_db }}

# Domain
DOMAIN={{ vault_domain }}
ACME_EMAIL={{ vault_acme_email }}

# IP whitelist for admin panels
HOME_IP={{ vault_home_ip }}

# Backend
DATABASE_URL=postgresql+asyncpg://{{ vault_postgres_user }}:{{ vault_postgres_password }}@postgres:5432/{{ vault_postgres_db }}
