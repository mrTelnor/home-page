# PostgREST config — env vars are substituted by PostgREST at startup.

db-uri = "$(KNOWLEDGE_DB_URI)"
db-schemas = "public"

# Anon role not set — every request requires JWT with role: knowledge_rw claim.
db-anon-role = ""

jwt-secret = "$(KNOWLEDGE_JWT_SECRET)"
jwt-aud = "knowledge"

server-host = "0.0.0.0"
server-port = 3000

openapi-mode = "follow-privileges"
