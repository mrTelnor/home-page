# Логи всех задач идут в stdout PID 1 (/proc/1/fd/1) — попадают в `docker logs cron`
# и не теряются при пересоздании контейнера.

# Бэкап БД на Яндекс.Диск (3:00 GMT+3 = 00:00 UTC)
0 0 * * * /usr/local/bin/backup.sh > /proc/1/fd/1 2>&1

# Утренний цикл (8:00 GMT+3 = 05:00 UTC):
# 1. Создать меню на сегодня
# 2. Не-админам — короткое уведомление о меню
# 3. Админам — единый дайджест: расписание из Google Calendar + меню дня
0 5 * * * curl -s -X POST http://backend:8000/api/menus/create-daily -H "X-Cron-Secret: $CRON_SECRET" -H "Content-Type: application/json" -d '{}' > /proc/1/fd/1 2>&1 && curl -s -X POST http://bot:8080/notify -H "X-Cron-Secret: $CRON_SECRET" -H "Content-Type: application/json" -d '{"event":"menu_created"}' > /proc/1/fd/1 2>&1 && curl -s -X POST "http://bot:8080/check-calendar?digest=true" -H "X-Cron-Secret: $CRON_SECRET" > /proc/1/fd/1 2>&1

# Финализировать список (13:00 GMT+3 = 10:00 UTC)
0 10 * * * curl -s -X POST http://backend:8000/api/menus/finalize -H "X-Cron-Secret: $CRON_SECRET" -H "Content-Type: application/json" -d '{}' > /proc/1/fd/1 2>&1 && curl -s -X POST http://bot:8080/notify -H "X-Cron-Secret: $CRON_SECRET" -H "Content-Type: application/json" -d '{"event":"voting_opened"}' > /proc/1/fd/1 2>&1

# Закрыть голосование (17:00 GMT+3 = 14:00 UTC)
0 14 * * * curl -s -X POST http://backend:8000/api/menus/close-voting -H "X-Cron-Secret: $CRON_SECRET" -H "Content-Type: application/json" -d '{}' > /proc/1/fd/1 2>&1 && curl -s -X POST http://bot:8080/notify -H "X-Cron-Secret: $CRON_SECRET" -H "Content-Type: application/json" -d '{"event":"voting_closed"}' > /proc/1/fd/1 2>&1

# Календарь: проверка часовых напоминаний и встроенных reminders каждые 5 минут
*/5 * * * * curl -s -X POST http://bot:8080/check-calendar -H "X-Cron-Secret: $CRON_SECRET" > /proc/1/fd/1 2>&1
